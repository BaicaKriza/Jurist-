# =============================================================================
# Jurist Pro — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Railway provides this automatically as DATABASE_URL
# Format: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/juristdb

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── OpenAI (optional — falls back to mock responses) ─────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Storage ───────────────────────────────────────────────────────────────────
# Local storage path for uploaded procedure documents
STORAGE_PATH=/app/storage
STORAGE_TYPE=local

# ── MinIO (optional — app uses local storage if not set) ─────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jurist-documents
MINIO_USE_SSL=false

# ── Seed admin (used by seed.py) ──────────────────────────────────────────────
ADMIN_EMAIL=admin@jurist.al
ADMIN_PASSWORD=Admin123!
ADMIN_FULL_NAME=Administrator
RESET_ADMIN_PASSWORD=false

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set this in Vercel dashboard under Environment Variables
VITE_API_URL=https://your-railway-app.railway.app
