# Jurist — Development environment (Codespace / local without Docker)
DATABASE_URL=postgresql+psycopg2://jurist:jurist@localhost:5432/jurist
SECRET_KEY=dev-secret-key-jurist-2024-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# MinIO — nëse nuk ke MinIO, dokumentet nuk do të shkarkohen
# por API-ja do të funksionojë
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jurist-documents
MINIO_USE_SSL=false

REDIS_URL=redis://localhost:6379/0

# OpenAI — opsional, pa këtë analiza janë mock
OPENAI_API_KEY=

ENVIRONMENT=development
MAX_UPLOAD_SIZE_MB=50
