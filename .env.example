# Copy this file to .env and fill in the values
# cp .env.example .env

# OpenAI API Key (required for AI analysis features)
OPENAI_API_KEY=sk-your-openai-key-here

# Database (auto-configured in Docker)
POSTGRES_USER=jurist
POSTGRES_PASSWORD=jurist
POSTGRES_DB=jurist

# MinIO Object Storage (auto-configured in Docker)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Backend JWT Secret (CHANGE IN PRODUCTION!)
SECRET_KEY=super-secret-jwt-key-change-in-production-2024

# Environment
ENVIRONMENT=development
