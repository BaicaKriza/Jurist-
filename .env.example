# ── Backend ───────────────────────────────────────────────────────────────────
# For local dev outside Docker use localhost; inside Docker Compose use "db"
DATABASE_URL=postgresql+psycopg2://jurist:jurist@localhost:5432/jurist
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
REDIS_URL=redis://localhost:6379/0

# MinIO / object storage (optional – app falls back to local ./uploads/)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jurist-documents
MINIO_USE_SSL=false

# OpenAI (optional – falls back to mock analysis when missing)
OPENAI_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Where Vite proxies /api calls (only needed if overriding default 127.0.0.1:8000)
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000
